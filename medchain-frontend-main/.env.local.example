# MedChain Frontend Environment Configuration Example
# Copy this file to .env.local and fill in the values for local development.
# Do NOT commit the actual .env.local file to version control.

# Google OAuth Client ID for sign-in and registration.
# Reference file: src/app/login/page.tsx
# What breaks if missing: Google Sign-In and Registration buttons will be disabled,
# and a warning will be logged to the console to prevent broken OAuth flows.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Base URL for the primary Django Backend API (typically running on port 8000).
# Reference file: src/lib/api/client.ts
# What breaks if missing: Defaults to 'http://localhost:8000'. Direct API communication
# (e.g., standard login/registration, care relationships, access requests) will fail
# in any deployed environment if the backend is not on localhost:8000.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Base URL for the FastAPI RAG (Retrieval-Augmented Generation) Service (typically running on port 8001).
# Reference file: src/lib/api/rag.ts
# What breaks if missing: Defaults to 'http://localhost:8001/api/v1'. AI medical chat assistance,
# record reindexing, and question bank queries will fail if the RAG service is not reachable
# at the default localhost fallback.
NEXT_PUBLIC_RAG_URL=http://localhost:8001/api/v1

# Server-side JWT secret — MUST match Django's SECRET_KEY (medchain_backend/settings.py)
# and the RAG service JWT_SECRET (medchain-rag/config.py).
# Reference files: src/proxy.ts, src/app/api/auth/session/route.ts
# What breaks if missing: The edge middleware cannot verify the session cookie, so ALL
# protected routes will redirect to /login even for authenticated users. The session
# API route will return 500 and login will fail to set the httpOnly cookie.
# IMPORTANT: No NEXT_PUBLIC_ prefix — this must NEVER be sent to the browser.
JWT_SECRET=django-insecure-=368c99s73=ih5%4*mlh1f()0zkovo7#!j2#-j*=%4#3h-iat%
